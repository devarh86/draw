<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".ui.fragments.drawing.DrawingFramesFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolBar"
        android:layout_width="0dp"
        android:layout_height="?android:attr/actionBarSize"
        android:background="@color/container_clr_activity"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backPress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:padding="@dimen/_6sdp"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="@+id/toolBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/toolBar" />

        <TextView
            android:id="@+id/doneBtn"
            style="@style/headingTextOnBoarding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_8sdp"
            android:background="@drawable/rounded_red_btn_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="6dp"
            android:text="@string/done"
            android:textColor="@color/white"
            android:textSize="@dimen/_12sdp"
            app:layout_constraintBottom_toBottomOf="@+id/toolBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/fullMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_18sdp"
            android:src="@drawable/ic_full_mode_off"
            app:layout_constraintBottom_toBottomOf="@+id/toolBar"
            app:layout_constraintEnd_toStartOf="@+id/doneBtn"
            app:layout_constraintTop_toTopOf="@+id/toolBar" />

        <ImageView
            android:id="@+id/music"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_18sdp"
            android:src="@drawable/ic_music_off"
            app:layout_constraintBottom_toBottomOf="@+id/fullMode"
            app:layout_constraintEnd_toStartOf="@+id/fullMode"
            app:layout_constraintTop_toTopOf="@+id/fullMode" />

        <ImageView
            android:id="@+id/btnRedo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_18sdp"
            android:src="@drawable/ic_redo"
            app:layout_constraintBottom_toBottomOf="@+id/fullMode"
            app:layout_constraintEnd_toStartOf="@+id/music"
            app:layout_constraintTop_toTopOf="@+id/fullMode" />

        <ImageView
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_18sdp"
            android:src="@drawable/ic_undo"
            app:layout_constraintBottom_toBottomOf="@+id/fullMode"
            app:layout_constraintEnd_toStartOf="@+id/btnRedo"
            app:layout_constraintTop_toTopOf="@+id/fullMode" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/brushLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_4sdp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/brushSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/seekBarSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_6sdp"
                android:max="30"
                android:min="2"
                android:padding="0dp"
                android:progress="2"
                android:progressBackgroundTint="#AFAFAF"
                android:progressDrawable="@drawable/seekbar"
                android:progressTint="#4B5563"
                android:thumb="@drawable/thumb_icon"
                android:thumbOffset="0dp"
                android:valueFrom="2"
                android:valueTo="30"
                app:haloColor="#4B5563"
                app:labelBehavior="gone"
                app:layout_constraintBottom_toBottomOf="@+id/brushSize"
                app:layout_constraintEnd_toStartOf="@+id/tvBrushValue"
                app:layout_constraintStart_toEndOf="@+id/brushSize"
                app:layout_constraintTop_toTopOf="@+id/brushSize" />

            <TextView
                android:id="@+id/tvBrushValue"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="2%"
                android:textColor="@color/text_color"
                android:textSize="@dimen/_9sdp"
                app:layout_constraintBottom_toBottomOf="@+id/seekBarSize"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/seekBarSize"
                app:layout_constraintTop_toTopOf="@+id/seekBarSize" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/offSetLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_4sdp">

            <ImageView
                android:id="@+id/offSetSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/seekBarOffSetSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_6sdp"
                android:max="100"
                android:min="0"
                android:padding="0dp"
                android:progress="0"
                android:progressBackgroundTint="#AFAFAF"
                android:progressDrawable="@drawable/seekbar"
                android:progressTint="#4B5563"
                android:thumb="@drawable/thumb_icon"
                android:thumbOffset="0dp"
                android:valueFrom="0"
                android:valueTo="100"
                app:haloColor="#4B5563"
                app:labelBehavior="gone"
                app:layout_constraintBottom_toBottomOf="@+id/offSetSize"
                app:layout_constraintEnd_toStartOf="@+id/tvBrushOffSetValue"
                app:layout_constraintStart_toEndOf="@+id/offSetSize"
                app:layout_constraintTop_toTopOf="@+id/offSetSize" />

            <TextView
                android:id="@+id/tvBrushOffSetValue"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0%"
                android:textColor="@color/text_color"
                android:textSize="@dimen/_9sdp"
                app:layout_constraintBottom_toBottomOf="@+id/seekBarOffSetSize"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/seekBarOffSetSize"
                app:layout_constraintTop_toTopOf="@+id/seekBarOffSetSize" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/bottomLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/_8sdp">

            <TextView
                android:id="@+id/ColorMode"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_color_unselected"
                android:gravity="center"
                android:text="@string/color"
                android:textColor="@color/text_color_drawing_screen"
                android:textSize="@dimen/_10sdp" />

            <TextView
                android:id="@+id/brushMode"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_brush"
                android:gravity="center"
                android:text="@string/brush"
                android:textColor="@color/text_color_drawing_screen"
                android:textSize="@dimen/_10sdp" />

            <TextView
                android:id="@+id/offSetMode"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_offset"
                android:gravity="center"
                android:text="@string/off_set"
                android:textColor="@color/text_color_drawing_screen"
                android:textSize="@dimen/_10sdp" />

            <TextView
                android:id="@+id/opacityMode"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_opacity"
                android:gravity="center"
                android:text="@string/opacity"
                android:textColor="@color/text_color_drawing_screen"
                android:textSize="@dimen/_10sdp" />

            <TextView
                android:id="@+id/eraserMode"
                style="@style/headingTextOnBoarding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_eraser"
                android:gravity="center"
                android:text="@string/eraser"
                android:textColor="@color/text_color_drawing_screen"
                android:textSize="@dimen/_10sdp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="@dimen/_6sdp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.1"
                android:src="@drawable/ic_prev_unselected" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:gravity="center"
                android:text="1/2" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.1"
                android:src="@drawable/ic_next_unselected" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
